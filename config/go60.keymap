/* SYM and NAV layer goes to GREEK */
/ {
    conditional_layers {
        compatible = "zmk,conditional-layers";
        condition_greeks {
            if-layers = <LAYER_SYM LAYER_NAV>;
            then-layer = <LAYER_GREEK>;
        };
        condition_fncyzns {
            if-layers = <LAYER_SYM LAYER_WNDWMGMT>;
            then-layer = <LAYER_FNCYZNS>;
        };
    };
};

