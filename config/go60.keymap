/* Automatically generated keymap */
/ {
    keymap {
        compatible = "zmk,keymap";

        LAYER_Base {
            bindings = <
            &none           &none           &none           &none       &none           &magic LAYER_Magic 0                                                    &none       &none           &none       &none       &none       &none
            &mt LCTRL TAB   &kp X           &kp V           &kp L       &kp C           &kp W                                                                   &kp K       &kp H           &kp G       &kp F       &kp Q       &mt RCTRL DE_SS
            &none           &hml LGUI U     &hml LALT I     &hml LSFT A &hml LCTRL E    &kp O                                                                   &kp S       &hmr LCTRL N    &hmr LSFT R &hmr LALT T &hmr LGUI D &kp DE_Y
